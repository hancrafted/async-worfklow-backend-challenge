{
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@turf/turf": "^7.1.0",
    "@types/geojson": "^7946.0.15",
    "bcrypt": "^5.1.1",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.3",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.32",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "bash -c 'tsc --noEmit -p tsconfig.eslint.json'",
      "vitest related --run"
    ]
  }
}
